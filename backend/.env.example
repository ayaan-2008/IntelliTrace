# Database (SQLite - file-based, no server needed)
DATABASE_URL=sqlite+aiosqlite:///./intellitrace.db

# Security
JWT_SECRET_KEY=change-me-in-production-use-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:8501","http://localhost:8502","http://127.0.0.1:8501"]

# Device
DEVICE_API_KEY_LENGTH=64
DEVICE_ONLINE_THRESHOLD_SECONDS=300

# ML
ML_MODEL_DIR=./ml_models
PERSON_VERIFICATION_THRESHOLD=0.7

# Notifications (optional for MVP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
